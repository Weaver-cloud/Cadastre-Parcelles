{
  "name": "cadastre",
  "version": "1.0.0",
  "description": "Extraction et visualisation automatique de parcelles cadastrales",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "cadastre": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "level1": "tsx src/level1.ts",
    "level2": "tsx src/level2.ts",
    "level3": "tsx src/level3.ts",
    "level4": "tsx src/level4.ts",
    "dev": "tsx --watch src/cli.ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "pdf-lib": "^1.17.1",
    "proj4": "^2.9.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/proj4": "^2.5.5",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
